@page "/"
@inject IJSRuntime JSRuntime
@inject Supabase.Client SupabaseClient // 🟢 Supabaseをこの画面で使えるように追加
@implements IDisposable

<h1>バーコードテスト</h1>

<button @onclick="LaunchCamera" style="padding: 10px 20px; font-size: 16px; margin-bottom: 15px;">
    カメラを起動する
</button>

<div id="reader" style="width: 100%; max-width: 500px; border: 1px solid #ccc; min-height: 300px;"></div>

@code {
    private DotNetObjectReference<Home>? objRef;

    private async Task LaunchCamera()
    {
        objRef = DotNetObjectReference.Create(this);
        try
        {
            await JSRuntime.InvokeVoidAsync("startCamera", objRef);
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"エラーが発生しました: {ex.Message}");
        }
    }

    // 🟢 バーコードを検知したらJSから呼ばれるC#の関数（ここにSupabase保存を追加）
    [JSInvokable]
    public async Task OnScan(string code)
    {
        // 1. まずは画面に通知を出す
        await JSRuntime.InvokeVoidAsync("alert", $"読み取り成功！\n値: {code}");

        try
        {
            // 2. 保存するデータのモデルを作成
            var newBarcode = new BarcodeModel
            {
                Code = code
            };

            // 3. Supabaseの「barcodes」テーブルに保存！
            await SupabaseClient.From<BarcodeModel>().Insert(newBarcode);
            
            Console.WriteLine($"Supabaseへの保存に成功しました: {code}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Supabaseへの保存中にエラーが発生: {ex.Message}");
            await JSRuntime.InvokeVoidAsync("alert", $"DB保存エラー: {ex.Message}");
        }
    }

    public void Dispose() => objRef?.Dispose();
}