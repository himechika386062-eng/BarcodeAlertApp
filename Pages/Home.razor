@page "/"
@inject IJSRuntime JSRuntime
@inject Supabase.Client SupabaseClient
@inject HttpClient Http // 🟢 API通信用のHttpClientを追加
@implements IDisposable

<h1>バーコード書籍検索テスト</h1>

<button @onclick="LaunchCamera" style="padding: 10px 20px; font-size: 16px; margin-bottom: 15px;">
    カメラを起動する
</button>

<div id="reader" style="width: 100%; max-width: 500px; border: 1px solid #ccc; min-height: 300px;"></div>

@if (scannedBook != null)
{
    <div class="card mt-3" style="max-width: 500px; padding: 20px; border-left: 5px solid #0d6efd;">
        <div class="card-body p-0">
            <h4 class="card-title" style="font-weight: bold; margin-bottom: 15px; color: #333;">
                @scannedBook.Title
            </h4>
            <ul class="list-unstyled" style="font-size: 15px; margin: 0; padding: 0;">
                <li style="margin-bottom: 8px;"><strong>著者：</strong> @scannedBook.Author</li>
                <li style="margin-bottom: 8px;"><strong>出版社：</strong> @scannedBook.Publisher</li>
                <li><strong>出版年月：</strong> @FormatPubDate(scannedBook.PubDate)</li>
            </ul>
        </div>
    </div>
}

@code {
    private DotNetObjectReference<Home>? objRef;
    private BookSummary? scannedBook; // 🟢 本の情報を画面表示用に保持する変数

    private async Task LaunchCamera()
    {
        objRef = DotNetObjectReference.Create(this);
        try
        {
            await JSRuntime.InvokeVoidAsync("startCamera", objRef);
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"エラーが発生しました: {ex.Message}");
        }
    }

    // バーコードを検知したらJSから呼ばれるC#の関数
    [JSInvokable]
    public async Task OnScan(string code)
    {
        try
        {
            // 一番最初に978（本の上側）から始まるかチェック
            if (!code.StartsWith("978"))
            {
                await JSRuntime.InvokeVoidAsync("alert", "本の上のバーコード（978から始まるコード）を枠に合わせてください。");
                return;
            }

            // 🟢 OpenBD APIから書籍の文字情報を取得する
            var apiResponse = await Http.GetFromJsonAsync<OpenBdResponse[]>($"https://api.openbd.jp/v1/get?isbn={code}");
            
            string bookTitle = "不明な書籍";

            if (apiResponse != null && apiResponse.Length > 0 && apiResponse[0] != null)
            {
                scannedBook = apiResponse[0].Summary;
                if (scannedBook != null)
                {
                    bookTitle = scannedBook.Title;
                }
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("alert", "書籍情報が見つかりませんでした。");
                scannedBook = null;
            }

            StateHasChanged(); // 🟢 画面の表示を更新（タイトル等をカードに出す）

            // 1. Supabaseに同じバーコードが存在するか検索する
            var response = await SupabaseClient
                .From<BarcodeModel>()
                .Where(x => x.Code == code)
                .Get();

            // 2. すでに登録されているかどうかの条件分岐
            if (response.Models.Count > 0)
            {
                // 【重複あり】
                await JSRuntime.InvokeVoidAsync("alert", $"⚠️ 警告：『{bookTitle}』はすでに登録されています！");
            }
            else
            {
                // 【重複なし】タイトル情報を添えてSupabaseに保存
                var newBarcode = new BarcodeModel
                {
                    Code = code,
                    Title = bookTitle
                };

                await SupabaseClient.From<BarcodeModel>().Insert(newBarcode);
                
                await JSRuntime.InvokeVoidAsync("alert", $"本を新しく登録しました！\n『{bookTitle}』");
                Console.WriteLine($"Supabaseへの新規保存に成功しました: {code}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"エラーが発生: {ex.Message}");
            await JSRuntime.InvokeVoidAsync("alert", $"エラー: {ex.Message}");
        }
    }

    // 🟢 出版年月を「2026年06月」のように整形するヘルパー関数
    private string FormatPubDate(string rawDate)
    {
        if (string.IsNullOrEmpty(rawDate)) return "不明";
        if (rawDate.Length >= 6)
        {
            return $"{rawDate.Substring(0, 4)}年{rawDate.Substring(4, 2)}月";
        }
        return rawDate;
    }

    public void Dispose() => objRef?.Dispose();
}